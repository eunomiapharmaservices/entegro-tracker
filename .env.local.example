NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Needed for "task assigned" email notifications. Sign up at resend.com,
# verify a domain you own (NOT lumen.com — the domain you send FROM, not the
# recipient's domain), create an API key, and set:
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL="Entegro Tracker <notifications@your-verified-domain.com>"

# Needed for Admins to delete user accounts from "Manage users". Find this
# under Project Settings -> API -> service_role key in Supabase.
# ⚠️ NEVER prefix this with NEXT_PUBLIC_ — it must stay server-only. It
# bypasses all Row Level Security, so treat it like a master password.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
