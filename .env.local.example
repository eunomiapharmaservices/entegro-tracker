NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Needed for "task assigned" email notifications. Sign up at resend.com,
# verify a domain you own (NOT lumen.com — the domain you send FROM, not the
# recipient's domain), create an API key, and set:
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL="Entegro Tracker <notifications@your-verified-domain.com>"
